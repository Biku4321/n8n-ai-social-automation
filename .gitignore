# =============================================================
#  n8n AI Social Media Automation — .gitignore
# =============================================================

# ─── Secrets (NEVER commit these) ────────────────────────────
.env
.env.local
.env.example
.env.*.local
*.pem
*.key
secrets/

# ─── n8n local data ──────────────────────────────────────────
.n8n/
n8n-data/
database.sqlite
n8n.log

# ─── Node / npm ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnp
.pnp.js

# ─── OS junk ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─── VS Code ─────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# ─── Logs & temp ─────────────────────────────────────────────
logs/
*.log
tmp/
temp/
.cache/

# ─── Screenshots / recordings (too heavy for git) ────────────
screenshots/*.mp4
screenshots/*.mov
screenshots/*.avi
# Keep .png screenshots (small, useful for docs)
!screenshots/*.png

# ─── Python (if any helper scripts) ─────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
venv/
.env/

# ─── Docker ──────────────────────────────────────────────────
docker-compose.override.yml