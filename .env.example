# =============================================================
#  n8n AI Social Media Automation — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# =============================================================

# ─── n8n Core ────────────────────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/webhook/social-media-trigger

# Set a strong random string for n8n encryption (required for credentials)
N8N_ENCRYPTION_KEY=your_random_32_char_string_here

# Optional: basic auth to protect your n8n instance
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ─── Google Gemini ───────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIza_your_gemini_key_here

# Model to use (gemini-1.5-pro recommended)
GEMINI_MODEL=gemini-1.5-pro

# ─── Leonardo AI ─────────────────────────────────────────────
# Get from: https://app.leonardo.ai → Account Settings → API Access
LEONARDO_API_KEY=your_leonardo_api_key_here

# Default model ID (Leonardo Diffusion XL — free tier works)
LEONARDO_MODEL_ID=b24e16ff-06e3-43eb-8d33-4416c2d75876

# Image dimensions
LEONARDO_IMAGE_WIDTH=1024
LEONARDO_IMAGE_HEIGHT=1024

# ─── Facebook ────────────────────────────────────────────────
# Get from: developers.facebook.com → Graph API Explorer
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_page_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# ─── Instagram ───────────────────────────────────────────────
# Same access token as Facebook (linked account)
INSTAGRAM_USER_ID=your_instagram_business_user_id_here
# INSTAGRAM_ACCESS_TOKEN uses FACEBOOK_PAGE_ACCESS_TOKEN above

# ─── Google Sheets ───────────────────────────────────────────
# Get Sheet ID from the URL: /spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# Sheet tab names (change if you rename the tabs)
SHEET_TAB_LOGS=Social Media Logs
SHEET_TAB_ERRORS=Error Logs

# ─── Optional: Notifications ─────────────────────────────────
# Uncomment to enable Slack alerts on workflow failure
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── Workflow Defaults ────────────────────────────────────────
DEFAULT_BRAND=Your Brand
DEFAULT_TONE=professional
DEFAULT_PLATFORMS=facebook,instagram
