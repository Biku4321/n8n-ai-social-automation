            },
            {
              "name": "message",
              "value": "={{ $json.content.facebook.caption + '\\n\\n' + $json.content.facebook.hashtags.map(h => '#' + h).join(' ') + '\\n\\n' + $json.content.facebook.cta }}"
            },
            {
              "name": "published",
              "value": "=true"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
