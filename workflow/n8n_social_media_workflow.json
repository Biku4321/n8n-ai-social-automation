      "id": "publish-instagram",
      "name": "Instagram - Publish",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2660, 360],
      "credentials": {
        "httpQueryAuth": {
          "id": "instagram-api",
          "name": "Instagram Graph API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Aggregate all posting results\nconst mergedData = $('Merge Content + Image').first().json;\n\nlet fbResult = null;\nlet igResult = null;\n\ntry { fbResult = $('Post to Facebook').first().json; } catch(e) { fbResult = { error: e.message }; }\ntry { igResult = $('Instagram - Publish').first().json; } catch(e) { igResult = { error: e.message }; }\n\nconst facebookSuccess = fbResult && fbResult.id && !fbResult.error;\nconst instagramSuccess = igResult && igResult.id && !igResult.error;\n\nreturn [{\n  json: {\n    run_id: mergedData.run_id,\n    topic: mergedData.topic,\n    brand: mergedData.brand,\n    timestamp: mergedData.timestamp,\n    image_url: mergedData.image_url,\n    image_generated: mergedData.image_generated,\n    \n    // Platform content\n    facebook_caption: mergedData.content?.facebook?.caption || '',\n    facebook_hashtags: (mergedData.content?.facebook?.hashtags || []).join(', '),\n    facebook_cta: mergedData.content?.facebook?.cta || '',\n    \n    instagram_caption: mergedData.content?.instagram?.caption || '',\n    instagram_hashtags: (mergedData.content?.instagram?.hashtags || []).join(', '),\n    instagram_cta: mergedData.content?.instagram?.cta || '',\n    \n    linkedin_caption: mergedData.content?.linkedin?.caption || '',\n    linkedin_hashtags: (mergedData.content?.linkedin?.hashtags || []).join(', '),\n    linkedin_cta: mergedData.content?.linkedin?.cta || '',\n    \n    youtube_title: mergedData.content?.youtube?.title || '',\n    youtube_description: mergedData.content?.youtube?.description || '',\n    \n    // Posting status\n    facebook_post_id: fbResult?.id || '',\n    facebook_status: facebookSuccess ? 'SUCCESS' : 'FAILED',\n    facebook_error: facebookSuccess ? '' : JSON.stringify(fbResult),\n    \n    instagram_post_id: igResult?.id || '',\n    instagram_status: instagramSuccess ? 'SUCCESS' : 'FAILED',\n    instagram_error: instagramSuccess ? '' : JSON.stringify(igResult),\n    \n    overall_status: (facebookSuccess || instagramSuccess) ? 'PARTIAL_SUCCESS' : 'FAILED',\n    posted_at: new Date().toISOString()\n  }\n}];"
      },
