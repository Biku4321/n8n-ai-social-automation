    {
      "parameters": {
        "jsCode": "// Global error handler\nconst error = $input.first().json;\nconst inputData = $('Input Validator').first()?.json || {};\n\nreturn [{\n  json: {\n    run_id: inputData.run_id || 'ERROR_' + Date.now(),\n    timestamp: new Date().toISOString(),\n    topic: inputData.topic || 'Unknown',\n    brand: inputData.brand || 'Unknown',\n    overall_status: 'ERROR',\n    error_message: error.message || JSON.stringify(error),\n    error_node: $execution?.activeNodeName || 'Unknown',\n    image_url: '',\n    facebook_status: 'NOT_ATTEMPTED',\n    instagram_status: 'NOT_ATTEMPTED'\n  }\n}];"
      },
