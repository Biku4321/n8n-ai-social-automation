        "method": "POST",
        "url": "https://graph.facebook.com/v18.0/{{ $credentials.pageId }}/photos",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
