    {
      "parameters": {
        "method": "POST",
        "url": "https://graph.instagram.com/v18.0/{{ $credentials.igUserId }}/media_publish",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $credentials.accessToken }}"
