      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "social-media-trigger"
    },
    {
      "parameters": {
        "jsCode": "// Validate and extract input\nconst body = $input.first().json.body || $input.first().json;\n\nif (!body.topic) {\n  throw new Error('Missing required field: topic');\n}\n\nconst topic = body.topic;\nconst brand = body.brand || 'Your Brand';\nconst tone = body.tone || 'professional';\nconst platforms = body.platforms || ['facebook', 'instagram', 'linkedin'];\nconst schedule_time = body.schedule_time || null;\n\nreturn [{\n  json: {\n    topic,\n    brand,\n    tone,\n    platforms,\n    schedule_time,\n    timestamp: new Date().toISOString(),\n    run_id: 'run_' + Date.now()\n  }\n}];"
      },
      "id": "input-validator",
      "name": "Input Validator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpQueryAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "key",
              "value": "={{ $credentials.apiKey }}"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": []
        },
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are a social media content expert. Generate content for the following topic.\\n\\nTopic: {{ $json.topic }}\\nBrand: {{ $json.brand }}\\nTone: {{ $json.tone }}\\n\\nGenerate a JSON response with EXACTLY this structure (no markdown, pure JSON):\\n{\\n  \\\"facebook\\\": {\\n    \\\"caption\\\": \\\"engaging Facebook caption (150-200 words)\\\",\\n    \\\"hashtags\\\": [\\\"hashtag1\\\", \\\"hashtag2\\\", \\\"hashtag3\\\", \\\"hashtag4\\\", \\\"hashtag5\\\"],\\n    \\\"cta\\\": \\\"call to action text\\\"\\n  },\\n  \\\"instagram\\\": {\\n    \\\"caption\\\": \\\"Instagram caption with emojis (100-150 words)\\\",\\n    \\\"hashtags\\\": [\\\"hashtag1\\\", \\\"hashtag2\\\", \\\"hashtag3\\\", \\\"hashtag4\\\", \\\"hashtag5\\\", \\\"hashtag6\\\", \\\"hashtag7\\\", \\\"hashtag8\\\", \\\"hashtag9\\\", \\\"hashtag10\\\"],\\n    \\\"cta\\\": \\\"call to action text\\\"\\n  },\\n  \\\"linkedin\\\": {\\n    \\\"caption\\\": \\\"professional LinkedIn post (200-250 words)\\\",\\n    \\\"hashtags\\\": [\\\"hashtag1\\\", \\\"hashtag2\\\", \\\"hashtag3\\\"],\\n    \\\"cta\\\": \\\"professional call to action\\\"\\n  },\\n  \\\"youtube\\\": {\\n    \\\"title\\\": \\\"YouTube video title\\\",\\n    \\\"description\\\": \\\"YouTube video description (100-150 words)\\\",\\n    \\\"hashtags\\\": [\\\"hashtag1\\\", \\\"hashtag2\\\", \\\"hashtag3\\\", \\\"hashtag4\\\", \\\"hashtag5\\\"],\\n    \\\"cta\\\": \\\"subscribe and like CTA\\\"\\n  },\\n  \\\"image_prompt\\\": \\\"detailed DALL-E/Leonardo AI image generation prompt for this topic\\\",\\n  \\\"video_prompt\\\": \\\"optional video generation prompt\\\"\\n}\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.8,\n    \"topK\": 40,\n    \"topP\": 0.95,\n    \"maxOutputTokens\": 2048\n  }\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "gemini-content-generator",
      "name": "Gemini Content Generator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [680, 300],
      "credentials": {
        "httpQueryAuth": {
          "id": "gemini-api-key",
          "name": "Gemini API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse Gemini response\nconst response = $input.first().json;\n\ntry {\n  const content = response.candidates[0].content.parts[0].text;\n  \n  // Clean JSON from markdown if present\n  let cleanJson = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  \n  const parsed = JSON.parse(cleanJson);\n  \n  // Pass through original input data too\n  const inputData = $('Input Validator').first().json;\n  \n  return [{\n    json: {\n      ...inputData,\n      content: parsed,\n      image_prompt: parsed.image_prompt,\n      video_prompt: parsed.video_prompt || null,\n      gemini_success: true\n    }\n  }];\n} catch (error) {\n  throw new Error('Failed to parse Gemini response: ' + error.message + ' | Raw: ' + JSON.stringify(response).substring(0, 500));\n}"
      },
      "id": "parse-gemini-response",
      "name": "Parse Gemini Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://cloud.leonardo.ai/api/rest/v1/generations",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"prompt\": \"{{ $json.image_prompt }}\",\n  \"modelId\": \"b24e16ff-06e3-43eb-8d33-4416c2d75876\",\n  \"width\": 1024,\n  \"height\": 1024,\n  \"num_images\": 1,\n  \"guidance_scale\": 7,\n  \"num_inference_steps\": 20,\n  \"public\": false\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "leonardo-generate-image",
      "name": "Leonardo AI - Generate Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1120, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "leonardo-api-key",
          "name": "Leonardo AI API Key"
        }
      }
    },
    {
      "parameters": {
        "amount": 15,
        "unit": "seconds"
      },
      "id": "wait-for-image",
      "name": "Wait for Image Generation",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1340, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://cloud.leonardo.ai/api/rest/v1/generations/{{ $('Leonardo AI - Generate Image').first().json.sdGenerationJob.generationId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 30000
        }
      },
      "id": "fetch-image-result",
      "name": "Fetch Image Result",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1560, 200],
      "credentials": {
        "httpHeaderAuth": {
          "id": "leonardo-api-key",
          "name": "Leonardo AI API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Extract image URL from Leonardo response\nconst leonardoResponse = $input.first().json;\nconst contentData = $('Parse Gemini Response').first().json;\n\nlet imageUrl = null;\ntry {\n  const generations = leonardoResponse.generations_by_pk;\n  if (generations && generations.generated_images && generations.generated_images.length > 0) {\n    imageUrl = generations.generated_images[0].url;\n  }\n} catch (e) {\n  console.log('Could not extract image URL:', e.message);\n}\n\nreturn [{\n  json: {\n    ...contentData,\n    image_url: imageUrl,\n    generation_id: $('Leonardo AI - Generate Image').first().json.sdGenerationJob?.generationId,\n    image_generated: imageUrl !== null\n  }\n}];"
      },
      "id": "extract-image-url",
      "name": "Extract Image URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 200]
    },
    {
      "parameters": {
        "jsCode": "// Merge content data with image URL\nconst contentData = $('Parse Gemini Response').first().json;\nconst imageData = $input.first().json;\n\nreturn [{\n  json: {\n    ...contentData,\n    image_url: imageData.image_url || 'https://placeholder.com/1024x1024',\n    image_generated: imageData.image_generated || false,\n    generation_id: imageData.generation_id || null\n  }\n}];"
      },
      "id": "merge-content-image",
      "name": "Merge Content + Image",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300]
    },
    {
