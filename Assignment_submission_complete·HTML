    <div class="card">
      <div class="card-title">1. Google Gemini API</div>
      <div class="api-step">
        <div class="step-num">1</div>
        <div class="step-content">
          <h4>Get API Key</h4>
          <p>Go to <strong>aistudio.google.com</strong> → Sign in → <strong>Get API Key</strong> → Create API Key → Select a GCP project</p>
        </div>
      </div>
